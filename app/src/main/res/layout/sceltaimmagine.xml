<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:stretchColumns="*">



    <TableRow
        android:id="@+id/row"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">


        <TextView
            android:layout_width="130dp"
            android:layout_height="match_parent"
            android:gravity="center|right"
            android:text="Scelta  "
            android:textColor="@color/white"
            android:background="@color/black"
            android:fontFamily="sans-serif-condensed"
            android:textSize="32dp"></TextView>
        <TextView
            android:layout_width="130dp"
            android:layout_height="match_parent"
            android:gravity="center|left"
            android:text=" Immagine"
            android:textColor="@color/white"
            android:background="@color/black"
            android:fontFamily="sans-serif-condensed"
            android:textSize="32dp"></TextView>
    </TableRow>
    <TableRow
        android:id="@+id/row1"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/simpleImageButton"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:onClick="immaginescelta1"
            android:src="@drawable/cane" />

        <ImageButton
            android:id="@+id/simpleImageButton1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/albero"
            android:onClick="immaginescelta2"/>

    </TableRow>
    <TableRow
        android:id="@+id/row2"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/simpleImageButton2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/casa"
            android:onClick="immaginescelta3"/>

        <ImageButton
            android:id="@+id/simpleImageButton3"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/coniglio"
            android:onClick="immaginescelta4"/>
    </TableRow>



</TableLayout>